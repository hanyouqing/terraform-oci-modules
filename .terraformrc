# =============================================================================
# Terraform CLI Configuration
# =============================================================================
#
# Use this config: export TF_CLI_CONFIG_FILE="$(pwd)/.terraformrc"
# Or copy to home: cp .terraformrc ~/.terraformrc
#
# Configures provider installation and plugin caching for OCI modules.
# =============================================================================

# -----------------------------------------------------------------------------
# Provider Installation
# -----------------------------------------------------------------------------

provider_installation {
  direct {}
}

# -----------------------------------------------------------------------------
# Plugin Cache (recommended)
# -----------------------------------------------------------------------------

# Use ~ (Terraform expands it). Do not use $HOME here — it is not expanded and breaks init/validate.
plugin_cache_dir = "~/.terraform.d/plugin-cache"

# -----------------------------------------------------------------------------
# OCI Authentication
# -----------------------------------------------------------------------------
#
# Terraform uses, in order:
# 1. Environment variables (OCI_TENANCY_OCID, OCI_USER_OCID, OCI_FINGERPRINT, OCI_PRIVATE_KEY_PATH)
# 2. OCI config file (~/.oci/config)
# 3. Instance principal (on OCI compute)
# 4. Resource principal (Functions/Container Instances)
#
# See .env.sh.example for environment variable setup.
#
