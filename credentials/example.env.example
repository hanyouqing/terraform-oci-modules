# Copy to credentials/<short-name>.env (e.g. credentials/work.env) and fill in values.
# Files named *.env are gitignored by this repo — never commit real credentials.
#
# Switch account by name (file basename without .env), e.g. credentials/ACI_ACCOUNT_NAME.env:
#   eval "$(./scripts/oci-use.sh ACI_ACCOUNT_NAME)"
# Or: source scripts/oci-use.sh && oci_use ACI_ACCOUNT_NAME
#
# See README: "Multiple OCI accounts"

export OCI_REGION="${OCI_REGION:-ap-seoul-1}"
export OCI_TENANCY_OCID="${OCI_TENANCY_OCID:-}"
export OCI_USER_OCID="${OCI_USER_OCID:-}"
export OCI_FINGERPRINT="${OCI_FINGERPRINT:-}"
export OCI_PRIVATE_KEY_PATH="${OCI_PRIVATE_KEY_PATH:-$HOME/.oci/oci_api_key.pem}"

export TF_VAR_compartment_id="${TF_VAR_compartment_id:-}"
export TF_VAR_tenancy_ocid="${TF_VAR_tenancy_ocid:-${OCI_TENANCY_OCID}}"
# Default home region ap-seoul-1 if neither TF_VAR_home_region nor OCI_REGION is set
export TF_VAR_home_region="${TF_VAR_home_region:-${OCI_REGION:-ap-seoul-1}}"
